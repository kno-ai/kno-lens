{
  "name": "@kno-lens/view",
  "version": "0.1.0",
  "description": "Presentation logic for LLM coding session visualization",
  "keywords": [
    "session",
    "visualization",
    "summary",
    "live-view"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kno-ai/kno-lens.git",
    "directory": "packages/view"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kno-lens/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
